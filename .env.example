DEMO_MODE=true
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Chat host (local or https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b

# Separate embeddings host (recommended: local Ollama even when chat uses cloud)
OLLAMA_EMBED_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

OPENROUTER_API_KEY=
OPENROUTER_MODEL=

GROQ_API_KEY=
GROQ_MODEL=

FIREWORKS_API_KEY=
FIREWORKS_MODEL=

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=

LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=

# --- RAG ---
# RAG_MODE: keyword | local | openai | ollama
RAG_MODE=ollama
EMBEDDING_PROVIDER=ollama
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

VECTOR_DB=local
APP_URL=http://localhost:3000
