// ParkPal PostgreSQL schema — production-ready models and relations.
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  createdAt DateTime @default(now())

  cases Case[]
}

model Case {
  id                  String    @id @default(uuid())
  userId              String
  pcnNumber           String?
  vehicleRegistration String?
  issuer              String?
  ticketType          String?
  issueDate           DateTime?
  appealDeadline      DateTime?
  status              String
  location            String?
  uploadedImageUrl    String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiAnalyses   AIAnalysis[]
  evidence     Evidence[]
  appeals      Appeal[]
  reminders    Reminder[]

  @@index([userId])
  @@index([pcnNumber])
  @@index([status])
}

model AIAnalysis {
  id              String   @id @default(uuid())
  caseId          String
  confidenceScore Float
  /// Prisma `Json` on PostgreSQL maps to JSONB (indexed-friendly binary JSON).
  analysisJson    Json     @db.JsonB
  createdAt       DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model Appeal {
  id          String    @id @default(uuid())
  caseId      String
  appealText  String    @db.Text
  pdfUrl      String?
  submitted   Boolean   @default(false)
  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model Evidence {
  id          String   @id @default(uuid())
  caseId      String
  imageUrl    String?
  description String?  @db.Text
  uploadedAt  DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model Reminder {
  id           String   @id @default(uuid())
  caseId       String
  reminderDate DateTime
  reminderType String
  completed    Boolean  @default(false)

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([reminderDate])
}
